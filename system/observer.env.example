# DRONGO observer + updater settings.
# Install to /etc/drongo/observer.env  (chmod 600, root). Read by the root-run
# observer and updater services.

DRONGO_SERVICE=drongo.service
DRONGO_REPO=/opt/drongo
DRONGO_RUNTIME=/var/lib/drongo/runtime
DRONGO_OBS_STATE=/var/lib/drongo/observer
DRONGO_PYTHON=/opt/drongo/.venv/bin/python

# Liveness / crash-loop thresholds
DRONGO_HEARTBEAT_MAX_AGE=900     # restart agent if heartbeat older than this (s)
DRONGO_MAX_RESTARTS=5            # restarts before treating as a crash-loop
DRONGO_MIN_HEALTHY_SECS=1200     # stay healthy this long before refreshing last-known-good

# Host health thresholds
DRONGO_TEMP_CRIT=90              # °C
DRONGO_LOAD_CRIT=12              # 1-min loadavg (≈ cores*3 for RK3399's 6 cores)
DRONGO_DISK_CRIT=96             # percent
DRONGO_ALLOW_REBOOT=0           # 1 = allow last-resort host reboot on sustained overload

# Routine self-update cadence
DRONGO_UPDATE_INTERVAL=86400    # seconds between routine git pulls

# Alerts (match your config.yaml ntfy topic)
DRONGO_NTFY_SERVER=https://ntfy.sh
DRONGO_NTFY_TOPIC=drongo-CHANGE-ME-to-something-long-and-random

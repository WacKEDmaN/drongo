# DRONGO observer + updater settings.
# Install to /etc/drongo/observer.env  (chmod 600, root). Read by the root-run
# observer and updater services.
#
# NOTE: systemd's EnvironmentFile does NOT strip inline "# comments" after a
# value — keep every comment on its OWN line, never after `KEY=value`.

DRONGO_SERVICE=drongo.service
DRONGO_REPO=/opt/drongo
DRONGO_RUNTIME=/var/lib/drongo/runtime
DRONGO_OBS_STATE=/var/lib/drongo/observer
DRONGO_PYTHON=/opt/drongo/.venv/bin/python

# Liveness / crash-loop thresholds
# restart agent if heartbeat older than this (seconds)
DRONGO_HEARTBEAT_MAX_AGE=900
# restarts before treating as a crash-loop
DRONGO_MAX_RESTARTS=5
# stay healthy this long (seconds) before refreshing last-known-good
DRONGO_MIN_HEALTHY_SECS=1200

# Host health thresholds
# CPU temperature critical, °C
DRONGO_TEMP_CRIT=90
# 1-min loadavg critical (~ cores*3 for RK3399's 6 cores)
DRONGO_LOAD_CRIT=12
# disk usage critical, percent
DRONGO_DISK_CRIT=96
# 1 = allow last-resort host reboot on sustained overload
DRONGO_ALLOW_REBOOT=0

# Routine self-update cadence
# seconds between routine git pulls
DRONGO_UPDATE_INTERVAL=86400

# Alerts — the observer/updater warn you about crash-loops, rollbacks, host
# health. Set the Discord webhook (same one as the agent) and/or an ntfy topic.
DRONGO_DISCORD_WEBHOOK=
DRONGO_NTFY_SERVER=https://ntfy.sh
DRONGO_NTFY_TOPIC=

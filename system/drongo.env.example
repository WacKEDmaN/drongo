# DRONGO agent secrets.  Install to /etc/drongo/drongo.env  (chmod 600, root).
# These are read by systemd and exported into the agent process. Leave a key
# blank to disable that cloud provider — the router will just skip it.

# --- Free cloud LLM providers ------------------------------------------------
CEREBRAS_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=

# --- Paid, last-resort (needs `pip install anthropic`; leave blank to skip) --
ANTHROPIC_API_KEY=

# --- Optional extra free providers (commented out in config.example.yaml) ----
# GITHUB_TOKEN=
# NVIDIA_API_KEY=

# --- Dashboard access control ------------------------------------------------
# Password for the web dashboard (HTTP Basic auth; log in with ANY username).
# The installer auto-fills this with a strong random value. If left blank, the
# dashboard refuses to bind to the LAN and serves on localhost only.
DRONGO_WEB_PASSWORD=
# Optional extra lock: only let these client IPs/subnets reach the dashboard,
# comma-separated, e.g. "192.168.1.50" or "192.168.1.0/24". Blank = any LAN host.
DRONGO_WEB_ALLOW=

# --- Alerts ------------------------------------------------------------------
# Discord channel webhook URL (Server Settings -> Integrations -> Webhooks).
# Used by the agent AND the root observer/updater for critical alerts.
DISCORD_WEBHOOK_URL=
